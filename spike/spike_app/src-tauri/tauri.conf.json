{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "spike_app",
  "version": "0.1.0",
  "identifier": "com.pattanunchutisavang.spike_app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "spike_app",
        "width": 900,
        "height": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "externalBin": [
      "binaries/spike-server"
    ]
  }
}
