{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AnyLive TTS",
  "version": "0.1.0",
  "identifier": "com.anylive.tts.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AnyLive TTS Automation",
        "width": 1024,
        "height": 720,
        "visible": false,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/sidecar-server/sidecar-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "single-instance": null,
    "dialog": null,
    "notification": null,
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Dunrip/anylive-tts-automation/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDRDFEQUY0QkQ2QjVBMTkKUldRWldtdTk5TnJSVE5jSzhzOUh5RFhKTCtPcHg1UGNjUysvS0dHUHZJWFJ1U2JLejhacVo2OTUK"
    }
  }
}
